# POCKET_POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/postgres?sslmode=disable
# POCKET_POSTGRES_SETUP=1      # optional: create/migrate LangGraph Postgres tables
# LANGSMITH_API_KEY=lsv2_...   # optional, only for the langgraph dev / Studio track
